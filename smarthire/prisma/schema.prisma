generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("seeker")
  createdAt DateTime @default(now())
  resetToken        String?
  resetTokenExpiry  DateTime?

  jobs      Job[]
  applications Application[] @relation("SeekerApplications")
}

model Job {
  id          String   @id @default(uuid())
  title       String
  company     String
  location    String
  type        String
  description String
  salary      String?
  skills      String[]
  isOpen      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recruiterId String
  recruiter   User     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  applications Application[]
}


model Application {
  id        String   @id @default(uuid())
  name      String
  resumeUrl String
  skills    String[]
  matchScore Float?
  createdAt DateTime @default(now())

  jobId  String
  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  seekerId String
  seeker   User   @relation("SeekerApplications", fields: [seekerId], references: [id], onDelete: Cascade)
}